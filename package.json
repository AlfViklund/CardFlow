{
  "name": "cardflow-platform",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "db:migrate": "tsx packages/db/migrate.ts",
    "check": "npm -ws --if-present run check",
    "lint": "npm -ws --if-present run lint",
    "test": "npm -ws --if-present run test"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/pg": "^8.11.11",
    "@types/react": "^19.1.3",
    "@types/react-dom": "^19.1.3",
    "concurrently": "^9.1.2",
    "tsx": "^4.20.5",
    "typescript": "^5.8.3"
  }
}

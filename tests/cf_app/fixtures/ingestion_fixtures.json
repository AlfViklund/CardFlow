      },
      "expected_analysis": {
        "status": "success",
        "quality_score": 85,
        "flags": [],
        "can_approve": true
      }
    },
    "main_plus_additional": {
      "description": "Main photo + 3 additional product photos",
      "files": {
        "main": {"filename": "product_main.jpg", "content_type": "image/jpeg", "size_bytes": 2097152, "dimensions": {"width": 3000, "height": 3000}},
        "additional": [
          {"filename": "product_angle1.jpg", "content_type": "image/jpeg", "size_bytes": 1800000, "dimensions": {"width": 3000, "height": 3000}},
          {"filename": "product_angle2.jpg", "content_type": "image/jpeg", "size_bytes": 1900000, "dimensions": {"width": 3000, "height": 3000}},
          {"filename": "product_detail.jpg", "content_type": "image/jpeg", "size_bytes": 2200000, "dimensions": {"width": 3000, "height": 3000}}

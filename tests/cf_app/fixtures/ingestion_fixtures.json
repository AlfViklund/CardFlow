  "invalid_input_scenarios": [
    {
      "id": "missing_main_photo",
      "description": "No main photo uploaded — required field missing",
      "files": {},
      "brief": "Some product description",
      "marketplaces": ["wildberries"],
      "expected": {
        "status": "blocked",
        "severity": "critical",
        "can_approve": false,
        "error_code": "MISSING_MAIN_PHOTO",
        "message": "Main product photo is required"
      }
    },
    {
      "id": "file_too_large",
      "description": "Main photo exceeds 10MB limit",
      "files": {
        "main": {"filename": "huge.tiff", "content_type": "image/tiff", "size_bytes": 52428800, "dimensions": {"width": 8000, "height": 8000}}
      },
      "expected": {
        "status": "blocked",
        "severity": "critical",
        "can_approve": false,
        "error_code": "FILE_TOO_LARGE",
        "message": "File size exceeds maximum of 10MB",
        "max_size_bytes": 10485760
      }
    },
    {
      "id": "invalid_file_type",
      "description": "Uploaded file is not an image (executable)",
      "files": {
        "main": {"filename": "product.exe", "content_type": "application/octet-stream", "size_bytes": 524288}
      },
      "expected": {
        "status": "blocked",
        "severity": "critical",
        "can_approve": false,
        "error_code": "INVALID_FILE_TYPE",
        "message": "Only image files are accepted (JPEG, PNG, WebP)",
        "allowed_types": ["image/jpeg", "image/png", "image/webp"]
      }
    },
    {
      "id": "low_resolution",
      "description": "Main photo below minimum resolution",
      "files": {
        "main": {"filename": "tiny.jpg", "content_type": "image/jpeg", "size_bytes": 5000, "dimensions": {"width": 50, "height": 50}}
      },
      "expected": {
        "status": "blocked",
        "severity": "critical",
        "can_approve": false,
        "error_code": "LOW_RESOLUTION",
        "message": "Image resolution below minimum requirements",
        "min_wb": {"width": 900, "height": 900},
        "min_ozon": {"width": 1000, "height": 1000}
      }
    },
    {
      "id": "corrupted_image",
      "description": "Uploaded file is a corrupted/unreadable image",
      "files": {
        "main": {"filename": "corrupt.jpg", "content_type": "image/jpeg", "size_bytes": 1024, "corrupted": true}
      },
      "expected": {
        "status": "blocked",
        "severity": "critical",
        "can_approve": false,
        "error_code": "CORRUPTED_IMAGE",
        "message": "Unable to read image file — file may be corrupted"
      }
    },
    {
      "id": "too_many_references",
      "description": "More than 5 reference images uploaded",
      "files": {
        "main": {"filename": "product_main.jpg", "content_type": "image/jpeg", "size_bytes": 2097152, "dimensions": {"width": 3000, "height": 3000}},
        "references": [
          {"filename": "ref1.jpg"}, {"filename": "ref2.jpg"}, {"filename": "ref3.jpg"},
          {"filename": "ref4.jpg"}, {"filename": "ref5.jpg"}, {"filename": "ref6.jpg"}
        ]
      },
      "expected": {
        "status": "blocked",
        "severity": "critical",
        "can_approve": false,
        "error_code": "TOO_MANY_REFERENCES",
        "message": "Maximum 5 reference images allowed",
        "max_references": 5,
        "provided": 6
      }
    },
    {
      "id": "empty_brief_warning",
      "description": "Brief text is empty — warning, not blocking",
      "files": {
        "main": {"filename": "product_main.jpg", "content_type": "image/jpeg", "size_bytes": 2097152, "dimensions": {"width": 3000, "height": 3000}}
      },
      "brief": "",
      "expected": {
        "status": "warning",
        "severity": "warning",
        "can_approve": true,
        "warning_code": "EMPTY_BRIEF",
        "message": "No brief text provided — analysis will rely solely on image content"
      }
    },
    {
      "id": "brief_too_long",
      "description": "Brief text exceeds 5000 character limit",
      "files": {
        "main": {"filename": "product_main.jpg", "content_type": "image/jpeg", "size_bytes": 2097152, "dimensions": {"width": 3000, "height": 3000}}
      },
      "brief_len_chars": 5001,
      "expected": {
        "status": "blocked",
        "severity": "critical",
        "can_approve": false,
        "error_code": "BRIEF_TOO_LONG",
        "message": "Brief text exceeds maximum of 5000 characters",
        "max_chars": 5000
      }
    },
    {
      "id": "non_square_aspect_ratio",
      "description": "Main photo has non-square aspect ratio — warning for WB",
      "files": {
        "main": {"filename": "wide.jpg", "content_type": "image/jpeg", "size_bytes": 2097152, "dimensions": {"width": 3000, "height": 1500}}
      },
      "expected": {
        "status": "warning",
        "severity": "warning",
        "can_approve": true,
        "warning_code": "NON_SQUARE_ASPECT",
        "message": "Non-square aspect ratio — marketplace may crop or reject"
      }
    },
    {
      "id": "png_with_transparency",
      "description": "PNG with transparent background — warning for marketplaces",
      "files": {
        "main": {"filename": "product_transparent.png", "content_type": "image/png", "size_bytes": 1500000, "dimensions": {"width": 2000, "height": 2000}, "has_transparency": true}
      },
      "expected": {
        "status": "warning",
        "severity": "warning",
        "can_approve": true,
        "warning_code": "TRANSPARENT_BACKGROUND",
        "message": "Image has transparent background — some marketplaces require solid background"
      }
    },
    {
      "id": "gif_not_accepted",
      "description": "GIF file format — not accepted by any marketplace",
      "files": {
        "main": {"filename": "product.gif", "content_type": "image/gif", "size_bytes": 500000, "dimensions": {"width": 1200, "height": 1200}}
      },
      "expected": {
        "status": "blocked",
        "severity": "critical",
        "can_approve": false,
        "error_code": "INVALID_FILE_TYPE",
        "message": "GIF format not accepted — use JPEG, PNG, or WebP",
        "allowed_types": ["image/jpeg", "image/png", "image/webp"]
      }
    },
    {
      "id": "zero_byte_file",
      "description": "Uploaded file is 0 bytes",
      "files": {
        "main": {"filename": "empty.jpg", "content_type": "image/jpeg", "size_bytes": 0}
      },
      "expected": {
        "status": "blocked",
        "severity": "critical",
        "can_approve": false,
        "error_code": "EMPTY_FILE",
        "message": "Uploaded file is empty"
      }
    },
    {
      "id": "filename_with_special_chars",
      "description": "Filename with special characters — should be sanitized",
      "files": {
        "main": {"filename": "product <main> & \"photo\".jpg", "content_type": "image/jpeg", "size_bytes": 2097152, "dimensions": {"width": 3000, "height": 3000}}
      },
      "expected": {
        "status": "success",
        "severity": "info",
        "can_approve": true,
        "sanitized_filename": "product_main_photo.jpg",
        "warning_code": "FILENAME_SANITIZED"
      }
    }
  ],
  "marketplace_rules": {
    "wildberries": {
      "min_resolution": {"width": 900, "height": 900},
      "max_file_size_bytes": 10485760,
      "max_title_length": 60,
      "max_additional_images": 10,
      "max_reference_images": 5,
      "accepted_formats": ["image/jpeg", "image/png", "image/webp"],
      "prohibited_keywords": ["подделка", "копия", "реплика", "18+", "порно"],
      "mandatory_fields": ["brand", "category", "name"],
      "preferred_aspect_ratio": "1:1",
      "background": "white_preferred"
    },
    "ozon": {
      "min_resolution": {"width": 1000, "height": 1000},
      "max_file_size_bytes": 20971520,
      "max_title_length": 120,
      "max_additional_images": 15,
      "max_reference_images": 5,
      "accepted_formats": ["image/jpeg", "image/png", "image/webp"],
      "prohibited_keywords": ["реплика", "фейк"],
      "mandatory_fields": ["brand"],
      "preferred_aspect_ratio": "1:1",
      "background": "white_required"
    },
    "wb_ozon_strictest": {
      "min_resolution": {"width": 1000, "height": 1000},
      "max_file_size_bytes": 10485760,
      "max_title_length": 60,
      "max_additional_images": 10,
      "max_reference_images": 5,
      "accepted_formats": ["image/jpeg", "image/png", "image/webp"],
      "prohibited_keywords": ["подделка", "копия", "реплика", "18+", "порно", "фейк"],
      "mandatory_fields": ["brand", "category", "name"],
      "preferred_aspect_ratio": "1:1",
      "background": "white_required"
    }
  },
  "quality_thresholds": {
    "excellent": {"min_score": 90, "severity": "pass"},
    "good": {"min_score": 75, "max_score": 89, "severity": "pass"},
    "acceptable": {"min_score": 60, "max_score": 74, "severity": "warning"},
    "poor": {"min_score": 40, "max_score": 59, "severity": "warning"},
    "critical": {"max_score": 39, "severity": "critical"}
  },
  "analysis_result_schema": {
    "project_id": "uuid",
    "uploaded_at": "iso8601",
    "marketplaces": ["string"],
    "main_image": {
      "filename": "string",
      "content_type": "string",
      "size_bytes": "integer",
      "dimensions": {"width": "integer", "height": "integer"},
      "content_hash": "sha256",
      "quality_score": "integer 0-100"
    },
    "additional_images": [{"filename": "string", "content_hash": "sha256"}],
    "reference_images": [{"filename": "string", "content_hash": "sha256"}],
    "brief": {"text": "string", "char_count": "integer"},
    "analysis": {
      "category": "string|null",
      "attributes": ["string"],
      "quality_flags": [
        {"code": "string", "severity": "critical|warning|info", "message": "string"}
      ],
      "overall_quality_score": "integer 0-100",
      "can_approve": "boolean",
      "blocking_reasons": ["string"],
      "warnings": ["string"]
    },
    "marketplace_validation": {
      "wildberries": {"passes": "boolean", "failures": ["string"], "warnings": ["string"]},
      "ozon": {"passes": "boolean", "failures": ["string"], "warnings": ["string"]}
    }
  },
